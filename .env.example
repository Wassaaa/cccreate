CC_WEBHOOK_TOKEN=change-me

# Local-only browser UI for reports.
CC_REPORT_VIEWER_PORT=8786

# Cloudflare API token with permission to edit DNS for the zone.
CF_API_TOKEN=put-your-cloudflare-token-here

# The hostname this webhook should use.
CF_DDNS_DOMAINS=cc-webhook.transcenders.online

# true keeps Cloudflare proxying enabled. false makes DNS point directly at your IP.
CF_DDNS_PROXIED=true
